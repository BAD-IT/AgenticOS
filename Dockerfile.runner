FROM python:3.12-slim

# Install g++ to support C++ compilation for the execution tests
RUN apt-get update -qq && \
    apt-get install -y -qq g++ && \
    rm -rf /var/lib/apt/lists/*

# Setup work directories
WORKDIR /app
COPY src/tools/runner_daemon.py /app/runner_daemon.py

# Keep the container alive by running the polling daemon
CMD ["python", "/app/runner_daemon.py"]
