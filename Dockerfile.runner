FROM python:3.12-slim

# Install g++ to support C++ compilation for the execution tests
RUN apt-get update -qq && \
    apt-get install -y -qq g++ && \
    rm -rf /var/lib/apt/lists/*

# Setup work directories
WORKDIR /app
COPY requirements-prod.txt .
RUN pip install python-dotenv
COPY src /app/src

# Keep the container alive by running the polling daemon
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "src.tools.runner_daemon"]
